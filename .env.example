# --- Aster API Credentials ---------------------------------------------------
# Recommended: Pro API V3 (EIP-712) — https://github.com/asterdex/api-docs
# Create an AGENT at asterdex.com → API Wallet → switch to "Pro API" at the top.
ASTER_USER=0xYourMainWalletAddress
ASTER_SIGNER=0xYourApiWalletAgentAddress
ASTER_SIGNER_PRIVATE_KEY=0xYourApiWalletPrivateKeyHex

# Optional: override REST host (default https://fapi.asterdex.com)
# ASTER_FAPI_BASE=https://fapi.asterdex.com

# Legacy (HMAC only — if you still have old API keys; not V3 Pro)
# ASTER_API_KEY=
# ASTER_SECRET_KEY=

# --- Multi-Asset Margin -------------------------------------------------------
# The bot automatically enables Multi-Asset Mode on startup.
# You just need to have ASTER and/or USDF deposited in your account.
#
# ASTER collateral ratio: 80%
#   -> 2000 ASTER @ $0.70 = $1,400 value -> $1,120 effective margin
#   -> Your idle ASTER earns Aster Asset Points without selling!
#
# USDF collateral ratio: 99.99%
#   -> Mint via Aster Earn (deposit USDT), or buy on Aster Spot
#
# Both assets earn Stage 6 Aster Asset Points = free bonus points on top.

# --- Operations checklist (read before live) --------------------------------
# - Single live funding_farmer process (two copies = double orders).
# - Cron/launchd: same OS user as .env; cd to repo root so paths resolve.
# - Backup .env (and any blacklist sidecar) before enabling auto config writes.
# - Tiered monitoring: (1) python profit_assistant.py watch|tips  (2) alert_watcher  (3) claude_advisor run
# - Kill switch: FARMING_HALT=true or touch FARMING_HALT_FILE — stops NEW opens only; exits still run.
# - One-cycle paper smoke (needs valid API keys): python3 funding_farmer.py --max-cycles 1

# --- Local ~10m live smoke (real orders; flatten on Ctrl+C) --------------------
# Do NOT end live tests with --max-cycles: when DRY_RUN=false, that exit leaves perps OPEN on Aster.
# Stop with Ctrl+C so funding_farmer runs the shutdown path and market-closes tracked longs.
# Preflight (no secret values printed): python3 scripts/verify_live_smoke_prereqs.py
# With optional Claude loop: python3 scripts/verify_live_smoke_prereqs.py --claude
# One-command small live (this process only; default flattens ALL Aster perps first):
#   bash scripts/local_live_smoke.sh
# Same + in-process code review + claude_advisor loop: python3 run_small_staged.py --live-small --with-claude
# Tune without editing .env: LIVE_SMALL_BUDGET=150 LIVE_SMALL_POOLS=1 bash scripts/local_live_smoke.sh
# Skip startup flatten (e.g. other perps you must keep): bash scripts/local_live_smoke.sh --no-clean-slate
# Optional advisor in a second terminal: bash scripts/claude_advisor_loop.sh
# Afterward: python3 scripts/verify_live_smoke_artifacts.py
# Optional: CYCLE_SNAPSHOT_ENABLE=true for richer claude_advisor payloads during the run.

# --- Fly.io (same keys as local .env; prefer fly secrets set over blind secrets import) ---
# Pre-deploy check (prints no secrets): python3 scripts/verify_fly_env.py   (optional: --strict)
# Single trading machine: fly scale count 1 -a <your-app>
# fly.toml mounts volume `data` at /data and sets TRADE_LOG_FILE / FUNDING_FARMER_LOG / ALERT_WATCHER_STATE_FILE there.
#   First deploy: fly may create the volume via initial_size; else: fly volumes create data --region fra --size 1
# Docker entrypoint runs funding_farmer.py; if ALERT_WATCHER_ENABLED=true and WEBHOOK_URL or Telegram is set,
#   alert_watcher.py also starts in the background on the same machine.
#
# --- Fly: multi-hour dry run + Claude (wallet-sized paper, no live orders) ---
# Bot-only on Fly (no docker-entrypoint Claude loop): fly.toml [env] sets CLAUDE_ADVISOR_LOOP_ON_FLY=false.
# If you ever set the loop via secrets, remove it or the secret wins: fly secrets unset CLAUDE_ADVISOR_LOOP_ON_FLY -a <app>
# Set via fly secrets (example names — replace <app> with fly.toml app name):
#   fly secrets set -a <app> \
#     DRY_RUN=true \
#     DRY_RUN_SIMULATED_MARGIN_USD=0 \
#     DELTA_NEUTRAL=false \
#     CLAUDE_ADVISOR_ENABLED=true \
#     CLAUDE_ADVISOR_LOOP_ON_FLY=true \
#     CLAUDE_ADVISOR_LOOP_SLEEP_SEC=180 \
#     ANTHROPIC_API_KEY=sk-ant-... \
#     ASTER_USER=... ASTER_SIGNER=... ASTER_SIGNER_PRIVATE_KEY=...
# Paths on the mounted volume (fly.toml [env] already sets TRADE_LOG_FILE / FUNDING_FARMER_LOG under /data):
#   fly secrets set -a <app> \
#     CYCLE_SNAPSHOT_ENABLE=true \
#     CYCLE_SNAPSHOT_FILE=/data/farmer_cycle.jsonl \
#     CLAUDE_ADVISOR_OUT_JSONL=/data/claude_advisor_out.jsonl \
#     CLAUDE_ADVISOR_LAST_RUN_FILE=/data/.claude_advisor_last_run
# Preflight (no secret values): python3 scripts/verify_fly_env.py
# Deploy: fly deploy -a <app>   then: fly scale count 1 --yes -a <app>
# If deploy errors on missing volume: fly volumes create data --region fra --size 1 -a <app>
#   or: FLY_APP_NAME=<app> bash scripts/fly_create_data_volume.sh
# Logs: fly logs -a <app>   ·   Advisor loop file on VM: tail -f /data/claude_loop.log
# Stop compute: fly scale count 0 -a <app>   (volume + /data files remain)
# Smallest real-money (local override, not Fly CMD): python3 run_small_staged.py --live-small --live-small-pools 3 --live-small-budget 120
# Main process on Fly: see Dockerfile / docker-entrypoint.sh (set DRY_RUN via fly secrets)
# Optional: same script without --live-small uses setdefault caps only; add --live-small-budget 80 to tune WALLET_MAX_USD
# fly.toml does not change Aster risk — only these env vars (as Fly secrets) control sizing.
# USDT-M perps always use collateral / leverage; there is no “no margin” mode. To limit risk,
# cap notional (WALLET_MAX_USD), use fewer slots (MAX_POSITIONS), and lower LEVERAGE (1–2).
#
# Suggested order:
#   1) Stage A on Fly: DRY_RUN=true, DRY_RUN_SIMULATED_MARGIN_USD=0 (wallet-sized) or 2000 (fixed paper), DELTA_NEUTRAL=false.
#      Tail logs: fly logs -a <your-app>
#   2) Stage B: DRY_RUN=false, WALLET_MAX_USD=150 (or 200–500), MAX_POSITIONS=2, LEVERAGE=2,
#      WALLET_MIN_USD=20 (15–25 is typical; lower sizes often hit exchange minNotional).
#   3) If WALLET_MAX_USD is very small, set RESERVE_SLOT_FOR_NEW_POOLS=false so reserved dry
#      powder does not block new opens (see Position Sizing section below).
#   4) Stage C: WALLET_MAX_USD=0, MAX_POSITIONS as desired, LEVERAGE per your risk tolerance.

# --- Staged live run (perp sizing + collateral) -------------------------------
# The farmer opens USDT-M perps only; spot USDF/ASTER/USDT feed multi-asset margin — no separate
# "spot vs perp amount" env. Deploy notional budget ≈ effective_margin × WALLET_DEPLOY_PCT × LEVERAGE,
# optionally capped by WALLET_MAX_USD (see funding_farmer.py compute_deploy_budget).
#
# Stage A — Dry run from real wallet (recommended): live rates/marks/balances, sizing = live margin, no orders:
#   DRY_RUN=true
#   DRY_RUN_SIMULATED_MARGIN_USD=0   # required for wallet-based deploy budget (default below)
#   DRY_RUN_SHOW_LIVE_WALLET_DETAILS=true   # show futures + spot tables (set false for quieter logs)
#   WALLET_MAX_USD=0
#   TRADE_LOG_FILE=trades_dry_run.csv  # optional
#   DELTA_NEUTRAL=false
#
# Stage A-alt — Fixed paper margin (no wallet sizing): same simulated orders, but deploy budget uses a fake USD cap
#   (e.g. CI or “what if $2k margin” without tying to your account). Live balance may still be fetched for logs.
#   DRY_RUN=true
#   DRY_RUN_SIMULATED_MARGIN_USD=2000
#   DRY_RUN_SHOW_LIVE_WALLET_DETAILS=false  # optional; true shows live rows + PAPER sizing row
#   WALLET_MAX_USD=0
#
# Stage B — Live small (real orders, cap total perp notional across slots):
#   DRY_RUN=false
#   DRY_RUN_SIMULATED_MARGIN_USD=0
#   WALLET_MAX_USD=150                 # try 150–500: hard ceiling on total deploy budget (USDT notional)
#   MAX_POSITIONS=2                    # optional: 1–3 for fewer concurrent names while you watch
#   LEVERAGE=2                         # optional: 1–2 is gentler for first live dollars than default 3
#
# Stage C — Full live:
#   DRY_RUN=false
#   WALLET_MAX_USD=0                   # remove cap
#   MAX_POSITIONS=7                    # restore your target diversification
#   With delta-neutral: validate in DRY_RUN, then run live on HL mainnet.

# --- Dry Run Mode -----------------------------------------------------------
# true  = live chain reads (rates, marks, balances GETs) + simulated perp orders; false = live Aster trading.
# When DELTA_NEUTRAL=true, DRY_RUN also skips real Hyperliquid orders (see delta_neutral.py)
DRY_RUN=true
# 0 = size deploy budget from your real futures effective margin (wallet-aware dry run).
# >0 = ignore wallet for sizing and use this USD as effective margin (fixed paper wallet).
DRY_RUN_SIMULATED_MARGIN_USD=0
# In dry run: print live futures + spot balance tables (reads /fapi/v2/balance + spot).
# Default true when unset (wallet + simulated perps together). Set false for quieter logs.
DRY_RUN_SHOW_LIVE_WALLET_DETAILS=true
# Optional: TRADE_LOG_FILE=trades_dry_run.csv

# --- Position Sizing & Diversification ---------------------------------------
# Slots: how many concurrent longs (raise for more diversification, lower for fewer names).
MAX_POSITIONS=7
# Reserve part of max deploy for future pool entries (same slots; does not reduce MAX_POSITIONS).
# true = reserve 1/MAX_POSITIONS of max notional (e.g. 7 slots ~14.3% dry powder).
# With a very small WALLET_MAX_USD (Fly small-live test), prefer false so the reserve slice
# does not leave too little budget to open meaningful positions.
RESERVE_SLOT_FOR_NEW_POOLS=true
# Or set RESERVE_DEPLOY_PCT=0.15 (15%); if set, overrides RESERVE_SLOT_FOR_NEW_POOLS.
# RESERVE_DEPLOY_PCT=

# LEVERAGE 1-2 is gentler for small live tests (less notional per $ collateral, lower liq risk).
LEVERAGE=3               # deploy budget uses margin x WALLET_DEPLOY_PCT x LEVERAGE (same live & dry)

# Wallet / balance sizing (live: API margin; dry: same unless DRY_RUN_SIMULATED_MARGIN_USD > 0)
# WALLET_DEPLOY_PCT = fraction of effective margin used in deploy budget (see startup banner).
WALLET_DEPLOY_PCT=0.80

# Optional hard ceiling (0 = no cap). Useful while testing.
# e.g. WALLET_MAX_USD=500 caps total deployed at $500 regardless of wallet size
WALLET_MAX_USD=0

# Don't open a position smaller than this (avoids below-minimum order errors).
# Typical range 15–25; going much lower often hits exchange minNotional on thin perps.
WALLET_MIN_USD=20

# Spot + futures balance logs: hide rows below this estimated USD (0 = show all non-zero)
BALANCE_DUST_USD=5
# Sum FUNDING_FEE from GET /fapi/v1/income for dashboard + startup (live only; not DRY_RUN).
INCOME_LOOKBACK_DAYS=30

# Rank-weighted sizing: top-ranked symbol gets this % of the deploy budget
# Remaining budget split equally among the rest
RANK_TOP_PCT=0.25

# Hard cap per symbol as % of deploy budget
MAX_SINGLE_PCT=0.30

# Correlation groups: won't hold both sides of a correlated pair simultaneously
CORR_GROUPS=BTCUSDT|WBTCUSDT,ETHUSDT|STETHUSDT|WETHUSDT

# --- Pool quality (liquidity) -------------------------------------------------
# Still Aster perps + multi-asset margin — Trading / Position / Aster Asset Points unchanged.
# Require minimum trailing 24h USDT quote volume (from GET /fapi/v1/ticker/24hr).
# Filters out thin perps that often top the funding leaderboard. 0 = no volume filter.
# Examples: 1000000 = $1M/day, 5000000 = $5M/day (stricter).
MIN_QUOTE_VOLUME_24H=0

# Optional: only consider these symbols (comma-separated). Example majors + large alts:
# SYMBOL_ALLOWLIST=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,XRPUSDT,ASTERUSDT

# --- Funding Rate Thresholds -------------------------------------------------
# Enter only if lastFundingRate >= MIN_FUNDING_RATE (same numeric units as GET /fapi/v1/premiumIndex).
# Interval may be 8h, 4h, 1h per symbol — APR in logs uses learned fundings/day when nextFundingTime steps.
# 0.0005 ≈ 0.05% per interval; ~54% APR only if that symbol settles 3×/day (8h).
MIN_FUNDING_RATE=0.0005

# Exit if the chosen funding series drops below this (default: REST lastFundingRate).
EXIT_FUNDING_RATE=0.0001
# true = for funding_dropped, prefer markPrice WebSocket field ``r`` when present (Binance-style estimate).
# FUNDING_EXIT_USE_WS_ESTIMATED=false
# Live-only: every N main-loop cycles, log if FUNDING_FEE income sign vs lastFundingRate disagrees with Aster doc convention (0=off).
# FUNDING_SIGN_SELF_CHECK_CYCLES=36

# --- Funding countdown / settlement gates (optional) ---------------------------
# Skip NEW opens if seconds-to-next-funding < this (0 = off). Uses REST nextFundingTime, or WS ``T`` when subscribed.
# FUNDING_OPEN_BLOCK_LAST_SEC=120
# After REST observes nextFundingTime step by ~one interval, block new opens on that symbol only (0 = off).
# FUNDING_OPEN_PAUSE_AFTER_SETTLE_SEC=120
# When flat: shorten idle sleep toward the nearest nextFundingTime among top-N snapshot symbols (still capped by POLL_INTERVAL_SEC).
# FUNDING_SYNC_IDLE_SLEEP=false
# FUNDING_SYNC_IDLE_TOP_N=20
# FUNDING_SYNC_BUFFER_SEC=10

# --- Settled funding history for pool ranking (optional) -----------------------
# Uses public GET /fapi/v1/fundingRate over the last H hours for the top-N symbols by snapshot rate (cached).
# 0 = disabled (default): rank/filter by lastFundingRate only.
# FUNDING_HISTORY_LOOKBACK_H=0
# FUNDING_HISTORY_TOP_N=20
# FUNDING_HISTORY_LIMIT=50
# FUNDING_HISTORY_CACHE_TTL_SEC=900
# Blend snapshot with history mean for sort: 0 = snapshot order (unless spike/filter removes names), 1 = mean only.
# FUNDING_RANK_BLEND_WEIGHT=0
# Require recent settlements vs MIN_FUNDING_RATE: "" (off), "min", or "median"
# FUNDING_HISTORY_REQUIRE=
# Treat as spike / skip pool if |snapshot| / max(|hist_mean|,eps) exceeds this (0 = off). Example: 3
# FUNDING_HISTORY_SPIKE_RATIO=0

# --- Fee-aware new opens (optional) -------------------------------------------
# Skip a candidate open if estimated round-trip taker fees need more than N funding settlements
# at |lastFundingRate| to break even (magnitude vs fees; verify long-side economics separately).
# 0 = disabled (default). Example: 24 ≈ skip very tiny |rate| vs fees. Tuning: profit_assistant.py summary
# ESTIMATED_TAKER_FEE_BPS=5
# MAX_FEE_BREAKEVEN_FUNDING_INTERVALS=0

# --- Risk Management ---------------------------------------------------------
# Stop loss on unrealized PnL (0.05 = 5% adverse vs entry)
STOP_LOSS_PCT=0.05
# Take profit on mark vs entry (0 = off). Try 0.04–0.08; lower = more exits/fees.
# TAKE_PROFIT_PCT=0.05

# --- Polling -----------------------------------------------------------------
# How often to scan when you have NO open perp positions (seconds).
POLL_INTERVAL_SEC=60
# How often to re-check stop loss + funding exit while ANY long is open (seconds).
# Use a low value with leverage so adverse moves are noticed before liquidation.
RISK_POLL_INTERVAL_SEC=15
# Mark-price WebSocket (wss://fstream.asterdex.com) for faster stop vs entry; REST stop still runs
MARK_PRICE_WS=true
# Log bid / ask / mid (+ mark) for open positions and top symbols (extra REST calls). Default off.
SHOW_BOOK_IN_LOGS=false
# Optional override for combined stream base (default: wss://fstream.asterdex.com/stream)
# FSTREAM_WS_URL=wss://fstream.asterdex.com/stream

# --- X (Twitter) API v2 + symbol boost (funding_farmer) ------------------------
# Requires X developer access with Recent search. Use ONE of: bearer token OR app key+secret.
# X_BEARER_TOKEN=
# X_API_KEY=
# X_API_SECRET=
# X_MAX_RESULTS=10
#
# Recent-search query (empty = news.py default, still Aave-oriented — set explicitly for Aster).
# Verify official @handles on x.com before relying on them. Example shape:
# X_SEARCH_QUERY=(from:Aster_DEX OR from:AsterFin) (listing OR pool OR perp OR USDT) -is:retweet lang:en
#
# Poll X every NEWS_POLL_SEC (shared with other news timing in config); symbols from tweets
# that appear in Aster exchangeInfo are boosted in the farmer scan for NEWS_SYMBOL_BOOST_TTL_SEC.
# NEWS_SYMBOL_BOOST_ENABLED=false
# NEWS_SYMBOL_BOOST_TTL_SEC=21600
# NEWS_POLL_SEC=300

# --- Profit assistant (optional CLI: watch | levers | tips | kpi | summary) ----------
# Tiered monitoring (no cost → alerts → Claude): (1) profit_assistant watch|tips
#   (2) alert_watcher.py  (3) claude_advisor.py run / cron
# false = disable levers/tips commands (watch still works)
PROFIT_ASSISTANT_ENABLED=true

# --- Symbol Blacklist --------------------------------------------------------
# Comma-separated symbols to never trade
BLACKLIST=

# --- Hyperliquid (Delta-Neutral hedge leg) -----------------------------------
# Mainnet only (no testnet). Your HL private key (hex, with or without 0x prefix)
HL_PRIVATE_KEY=your_hl_private_key_here
HL_WALLET_ADDRESS=your_hl_wallet_address_here

# Leverage on HL short leg (keep same as Aster for balanced hedge)
LEVERAGE_HL=3

# Hedge ratio: 1.0 = 100% delta neutral, 0.5 = 50% hedged
HEDGE_RATIO=1.0

# Min NET funding (Aster rate - HL rate) to bother entering (same units as API per interval)
# 0.0002 ≈ 0.02% per interval; annualized net depends on each venue's funding cadence
MIN_NET_FUNDING=0.0002

# Master switch for delta-neutral hedge leg (Hyperliquid short)
# false = Aster-only funding farm (default, no HL connection needed)
# true  = also opens a matching HL short to hedge price exposure
#         Requires HL_PRIVATE_KEY, HL_WALLET_ADDRESS when true
DELTA_NEUTRAL=false

# --- Kill switch (funding_farmer) --------------------------------------------
# true = skip opening NEW longs each cycle; stop-loss / take-profit / funding exits unchanged.
# Optional: set path and `touch` that file from SSH to halt without editing .env (remove file to resume).
FARMING_HALT=false
# FARMING_HALT_FILE=/tmp/aster_farming_halt

# --- Kill switch (exchange.py ladder path) -----------------------------------
# When true or the file exists: skip cancel/close/ladder placement (see exchange.py).
# TRADING_HALTED=false
# TRADING_HALT_FILE=

# --- Cycle snapshot JSONL (optional, for alert_watcher / claude_advisor) -----
# One compact JSON line per bot cycle; ring-trimmed to CYCLE_SNAPSHOT_MAX_LINES.
CYCLE_SNAPSHOT_ENABLE=false
# CYCLE_SNAPSHOT_FILE=farmer_cycle.jsonl
# CYCLE_SNAPSHOT_MAX_LINES=500

# --- Claude advisor (optional; pip install anthropic) ------------------------
# Suggestions only by default. Does not trade. Not called from the farmer loop.
#   CLAUDE_ADVISOR_ENABLED=true python claude_advisor.py run
#   python claude_advisor.py dry-run
# Cron example (every 4h, same user as .env, repo as cwd):
#   0 */4 * * * cd /path/to/aster-Funding-Farmer && set -a && . ./.env && set +a && CLAUDE_ADVISOR_ENABLED=true python3 claude_advisor.py run >>claude_advisor_runs.log 2>&1
CLAUDE_ADVISOR_ENABLED=false
# Set your real key from console.anthropic.com (never commit real keys to git).
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5
# Output token budget per run (higher = safer JSON completion, more cost). Haiku: 1024 is usually enough.
CLAUDE_ADVISOR_MAX_TOKENS=1024
# Hard cap on user JSON message size sent to the API (input tokens).
# CLAUDE_USER_MESSAGE_MAX_CHARS=120000
# Main bot log file (python funding_farmer.py), alert_watcher, and claude_advisor all default here:
FUNDING_FARMER_LOG=funding_farmer.log
# tail = last N lines; errors = only lines matching Traceback/error/exception/api error (smaller prompts).
CLAUDE_ADVISOR_LOG_MODE=tail
# Comma-separated trade CSV columns to send (* = all columns, verbose). Default is a compact set.
# CLAUDE_ADVISOR_CSV_COLUMNS=timestamp_utc,action,symbol,notional_usdt,funding_apr_pct,pnl_net_incl_funding_usdt,pnl_usdt,fees_usdt,hold_duration_min,close_reason
# Prepend stdout of `python profit_assistant.py summary` + `kpi` (bounded) to the advisor payload.
CLAUDE_ADVISOR_INCLUDE_KPI=false
# CLAUDE_ADVISOR_KPI_TIMEOUT_SEC=30
# CLAUDE_ADVISOR_KPI_DIGEST_MAX_CHARS=8000
# Optional: hide routine exchange.py INFO (order/audit lines may be INFO — use default INFO for full detail)
# LOG_EXCHANGE_LEVEL=WARNING
CLAUDE_ADVISOR_MAX_CSV_ROWS=60
CLAUDE_ADVISOR_MAX_LOG_LINES=250
CLAUDE_ADVISOR_MAX_SNAPSHOT_ROWS=30
# Min seconds between successful API runs (0 = no limit)
CLAUDE_ADVISOR_MIN_INTERVAL_SEC=3600
CLAUDE_ADVISOR_LAST_RUN_FILE=.claude_advisor_last_run
CLAUDE_ADVISOR_OUT_JSONL=claude_advisor_out.jsonl
# Reserved — must stay false until a guarded auto-apply feature exists (must respect FARMING_HALT).
CLAUDE_AUTO_APPLY=false

# --- Built-in periodic code review → Markdown (optional; funding_farmer daemon thread) -----
# Calls Anthropic on CODE_REVIEW_INTERVAL_SEC; appends to CODE_REVIEW_OUTPUT. Does not trade.
# Requires ANTHROPIC_API_KEY (e.g. fly secrets). Uses CLAUDE_MODEL.
# On Fly, output lives on the machine disk unless you use a Fly volume or copy off (e.g. fly ssh sftp).
# reviews/ is gitignored — do not commit generated MD into the trading repo.
CODE_REVIEW_ENABLED=false
# Seconds between wakeups (first run waits this long unless CODE_REVIEW_RUN_ONCE_ON_START=true).
CODE_REVIEW_INTERVAL_SEC=86400
# Min seconds between successful API runs (defaults to CODE_REVIEW_INTERVAL_SEC if unset).
# CODE_REVIEW_MIN_INTERVAL_SEC=86400
CODE_REVIEW_LAST_RUN_FILE=.code_review_last_run
# append = always append to CODE_REVIEW_OUTPUT; daily = reviews/advisor-YYYY-MM-DD.md (UTC) from stem.
CODE_REVIEW_OUTPUT_MODE=append
CODE_REVIEW_OUTPUT=reviews/advisor.md
# Comma-separated paths under repo root (never add .env or secret filenames).
CODE_REVIEW_PATHS=funding_farmer.py,exchange.py,config.py,delta_neutral.py,aster_client.py
CODE_REVIEW_MAX_FILE_BYTES=80000
CODE_REVIEW_MAX_TOTAL_BYTES=200000
CODE_REVIEW_MAX_TOKENS=4096
CODE_REVIEW_INCLUDE_LOG_TAIL=false
CODE_REVIEW_MAX_LOG_LINES=120
CODE_REVIEW_INCLUDE_TRADES_TAIL=false
CODE_REVIEW_MAX_TRADE_ROWS=40
CODE_REVIEW_INCLUDE_KPI=false
# CODE_REVIEW_KPI_TIMEOUT_SEC=30
# CODE_REVIEW_KPI_MAX_CHARS=8000
# Needs git in PATH (Dockerfile installs git for Fly). If git is missing, diff section is skipped.
CODE_REVIEW_INCLUDE_GIT_DIFF=false
# CODE_REVIEW_GIT_DIFF_TIMEOUT_SEC=45
# Dev: run one review soon after process start, then continue on interval.
CODE_REVIEW_RUN_ONCE_ON_START=false

# --- Claude advisor: low-token preset (optional) --------------------------------
# Uncomment to minimize API input/output cost; keep profit_assistant watch/tips for free monitoring.
# CLAUDE_ADVISOR_MAX_CSV_ROWS=25
# CLAUDE_ADVISOR_MAX_LOG_LINES=80
# CLAUDE_ADVISOR_MAX_SNAPSHOT_ROWS=10
# CLAUDE_ADVISOR_LOG_MODE=errors
# CLAUDE_ADVISOR_MAX_TOKENS=768
# CLAUDE_ADVISOR_MIN_INTERVAL_SEC=14400

# --- Alert watcher (optional; python alert_watcher.py) -----------------------
# Default off. Needs WEBHOOK_URL and/or TELEGRAM_BOT_TOKEN + TELEGRAM_CHAT_ID.
ALERT_WATCHER_ENABLED=false
# On first start, skip alerting on old CSV rows unless true:
# ALERT_CATCHUP_ON_START=true
WEBHOOK_URL=
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
ALERT_ON_CLOSE_REASONS=stop_loss,stop_loss_ws,take_profit,funding_dropped
ALERT_DEBOUNCE_SEC=300
ALERT_HEARTBEAT_OPEN=false
# ALERT_LOG_REGEX=(ERROR|Traceback|RuntimeError)
ALERT_WATCHER_STATE_FILE=.alert_watcher_state.json

# --- Preset ideas (copy active lines above; do not uncomment whole blocks) ---
# Carry-focused (pickier pools, smaller single-name cap):
# MIN_FUNDING_RATE=0.0008
# MIN_QUOTE_VOLUME_24H=5000000
# MAX_SINGLE_PCT=0.20
#
# Majors-tight (liquidity / “don’t get stuck” bias):
# SYMBOL_ALLOWLIST=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,XRPUSDT
# MIN_QUOTE_VOLUME_24H=10000000
